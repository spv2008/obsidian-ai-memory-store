{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -File \"$HOME/.config/obsidian-ai-memory-store/memory-session-hook.ps1\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
